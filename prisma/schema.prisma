datasource db {
    provider = "sqlite"
}

generator client {
    provider = "prisma-client"
    output   = "../src/generated/prisma"
}

generator pothos {
    provider = "prisma-pothos-types"
}

model Task {
    id        String   @id @default(cuid(2))
    title     String
    completed Boolean  @default(false)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}
